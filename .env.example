# Notch session tokens — extract from browser dev tools after logging in
#   Chrome DevTools → Application → Cookies → guardio.app.getnotch.dev
#   Copy the values of DS and DSR cookies
#
# For CI: store these as GitHub secrets NOTCH_DS_TOKEN and NOTCH_DSR_TOKEN
# For local dev: copy this file to .env and fill in your tokens
#   (interactive login still works if .env is absent)

NOTCH_DS_TOKEN=your_ds_cookie_value_here
NOTCH_DSR_TOKEN=your_dsr_cookie_value_here

# Optional: override base URL (default: https://guardio.app.getnotch.dev)
# NOTCH_BASE_URL=https://guardio.app.getnotch.dev
